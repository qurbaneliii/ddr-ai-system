# Core local application settings.
DDR_DATABASE_URL=sqlite:///data/processed/ddr_ai.db
DDR_RAW_DIR=data/raw
DDR_PROCESSED_DIR=data/processed
DDR_CACHE_DIR=data/cache
DDR_LOG_LEVEL=INFO
DDR_MAX_UPLOAD_MB=250
DDR_QUERY_TIMEOUT_SECONDS=10
DDR_DEFAULT_QUERY_LIMIT=200
DDR_MAX_QUERY_LIMIT=1000

# Local Ollama is the default and requires no secret.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=bge-m3:567m
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.1
OLLAMA_ENABLE_SEMANTIC_RETRIEVAL=false

# Remote mode is accepted only with HTTPS plus an authenticated reverse proxy.
# Keep the real value in ignored .env.local or Streamlit Secrets, never in Git.
OLLAMA_REMOTE_AUTH_TOKEN=
